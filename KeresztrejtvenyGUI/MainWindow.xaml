<Window x:Class="KeresztrejtvenyGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KeresztrejtvenyGUI"
        mc:Ignorable="d"
            Title="Keresztrejtvény készítő" Height="500" Width="500">
	<StackPanel Margin="10">
		<StackPanel Orientation="Horizontal" Margin="0,10">
			<TextBlock Text="Keresztrejtvény mérete [sor x oszlop]:" VerticalAlignment="Center"/>
			<ComboBox x:Name="cbSor" Width="45" Margin="5"/>
			<ComboBox x:Name="cbOszlop" Width="45" Margin="5"/>
		</StackPanel>

		<StackPanel Orientation="Horizontal" Margin="0,10">
			<Button Content="Keresztrejtvény létrehozása" Click="Letrehoz_Click" Margin="0,0,10,0"/>
			<Button Content="Keresztrejtvény mentése" Margin="0,0,10,0"/>
			<ComboBox x:Name="cbIndex" Width="40"/>
		</StackPanel>

		<ScrollViewer VerticalScrollBarVisibility="Auto">
			<UniformGrid x:Name="gridRacs"/>
		</ScrollViewer>
	</StackPanel>

</Window>
